# Copy this file to .env for local development. Never commit the real .env file.
# On Vercel: Project -> Settings -> Environment Variables, add the same keys there.

# MongoDB Atlas connection string. Get this from Atlas -> Connect -> Drivers,
# then swap in your own Database Access username/password. DO NOT use real
# credentials in this .env.example file — it's meant to be committed to git
# as a template, and .env (with your real value) is gitignored.
MONGODB_URI=mongodb+srv://<username>:<password>@<your-cluster>.mongodb.net/Blogger?retryWrites=true&w=majority

# Only needed if your API is on a different domain than the frontend.
# Leave unset when frontend + backend are deployed together on the same Vercel project.
# REACT_APP_API_BASE=https://your-backend-domain.com
